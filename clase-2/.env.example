# Generar con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Webhook de notificación principal — https://webhook.site
NOTIFICATION_WEBHOOK_URL=https://webhook.site/REEMPLAZAR

# Webhook para alertas (fallback / latencia alta / override). Puede ser el mismo o uno distinto.
ALERT_WEBHOOK_URL=https://webhook.site/REEMPLAZAR

# LlamaCloud — https://cloud.llamaindex.ai (API Keys)
LLAMA_CLOUD_API_KEY=llx-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
