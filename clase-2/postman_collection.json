    {
      "name": "PDF — LlamaCloud",
      "description": "Ingesta vía PDF. Requiere LLAMA_CLOUD_API_KEY en .env.\n\nPara tests reales reemplazar {{samplePdfUrl}} por la URL de un informe clínico público. El dummy.pdf sirve para smoke test (el markdown resultante está casi vacío y el flujo cae al fallback por falta de síntomas).",
      "item": [
        {
          "name": "PDF smoke test (dummy.pdf)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('respuesta tiene triage', () => pm.expect(b.triage).to.exist);",
                  "pm.test('log incluye inputSource pdf', () => pm.expect(b.log.inputSource).to.eql('pdf-llamacloud'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}{{webhookPathPdf}}", "host": ["{{baseUrl}}{{webhookPathPdf}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"P-C2-PDF-001\",\n  \"pdfUrl\": \"{{samplePdfUrl}}\"\n}"
            }
          }
        },
        {
          "name": "PDF — informe clínico real (reemplazar pdfUrl)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}{{webhookPathPdf}}", "host": ["{{baseUrl}}{{webhookPathPdf}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"P-C2-PDF-002\",\n  \"pdfUrl\": \"https://REEMPLAZAR_CON_URL_DE_TU_INFORME_CLINICO.pdf\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "PDF — test (/webhook-test) — anima canvas",
      "description": "Anima el canvas para la rama PDF. IMPORTANTE: requiere workflow Inactive + 'Execute workflow' en el canvas (o Listen for test event en el nodo 📄 Webhook PDF).\n\nAdvertencia: en n8n 2.x el nodo 'Wait 8s' suele fallar en modo test con 'Cannot read properties of null'. El canvas se anima hasta ese nodo. Para demo completa usar PDF producción.",
      "item": [
