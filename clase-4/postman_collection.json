{
  "info": {
    "name": "Clase 4 - Parsing + RAG sin vector DB (n8n Local)",
    "description": "Coleccion Postman para probar los workflows de clase 4 en n8n local.\n\nOrden sugerido:\n1. 09 - ingesta documental\n2. 10 - consulta RAG sobre embeddedChunks\n3. 11 - LlamaCloud + RAG end-to-end\n\nPuerto por defecto: 5681.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "clase-4-parsing-rag-local"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5681",
      "type": "string"
    },
    {
      "key": "samplePdfUrl",
      "value": "https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "09 - Ingesta documental",
      "description": "Convierte markdown o texto en documentos, chunks y embeddedChunks.",
      "item": [
        {
          "name": "09 - Ingesta con markdown simple",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('success true', () => pm.expect(b.success).to.eql(true));",
                  "pm.test('chunks > 0', () => pm.expect(b.chunks.length).to.be.greaterThan(0));",
                  "pm.test('embeddedChunks > 0', () => pm.expect(b.embeddedChunks.length).to.be.greaterThan(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/webhook/rag-ingesta-documental",
              "host": [
                "{{baseUrl}}/webhook/rag-ingesta-documental"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentTitle\": \"Prospecto demo\",\n  \"category\": \"prospecto\",\n  \"markdown\": \"Puede provocar dolor abdominal y nauseas en adultos mayores.\\n\\nConsultar si hay sangrado digestivo.\"\n}"
            }
          }
        },
        {
          "name": "09 - Ingesta con texto clínico estructurado",
          "event": [
