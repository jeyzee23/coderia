                  "const b = pm.response.json();",
                  "pm.test('document existe', () => pm.expect(b.documents[0]).to.be.an('object'));",
                  "pm.test('ingestion existe', () => pm.expect(b.ingestion).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
