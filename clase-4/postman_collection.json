    {
      "name": "10 - Consulta RAG",
      "description": "Consulta sobre embeddedChunks generados previamente.",
      "item": [
        {
          "name": "10 - Consulta con embeddedChunks demo",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('answer existe', () => pm.expect(b.answer).to.be.a('string'));",
                  "pm.test('retrieval existe', () => pm.expect(b.retrieval).to.be.an('object'));",
                  "pm.test('requiresHumanReview true', () => pm.expect(b.requiresHumanReview).to.eql(true));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/webhook/rag-consulta-documental",
              "host": [
